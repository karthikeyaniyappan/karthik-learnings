# Copy this file to `.env` and fill in your values. `.env*` files are gitignored.

# --- Trimble Identity credentials (server-side only) ---
# Read by the dev token proxy in vite.config.ts on the Node side. They are NOT
# prefixed with VITE_, so they are NEVER bundled into the browser.
# The dev server exchanges these for an access token via the OAuth 2.0
# client-credentials grant (POST https://id.trimble.com/oauth/token).
TRIMBLE_CLIENT_ID=
TRIMBLE_CLIENT_SECRET=
# The "scope" for client-credentials is your registered Client *name*.
TRIMBLE_CLIENT_NAME=
# Optional: override the token endpoint (defaults to https://id.trimble.com/oauth/token).
# TRIMBLE_TOKEN_URL=https://id.trimble.com/oauth/token

# --- Optional overrides for the embedded chat (browser-side, VITE_ prefixed) ---
# Use a token you already minted instead of the proxy (quick manual test):
# VITE_TRIMBLE_ACCESS_TOKEN=
# VITE_ASSIST_AGENT_ID=887868e6-7644-42b1-882e-fa9bafdb5464
# VITE_ASSIST_ENVIRONMENT=stage
