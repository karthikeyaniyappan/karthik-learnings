# Copy this file to `.env` and fill in values. `.env*` files are gitignored.

# Trimble Identity (TID) access token used to authenticate the embedded chat.
# Needed for a live, authenticated conversation. Leave blank to just render the UI.
VITE_TRIMBLE_ACCESS_TOKEN=

# Optional overrides (defaults live in src/assist/config.ts):
# VITE_ASSIST_AGENT_ID=887868e6-7644-42b1-882e-fa9bafdb5464
# VITE_ASSIST_ENVIRONMENT=stage
